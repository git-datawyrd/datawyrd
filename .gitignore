# Archivos de configuración sensibles
.env

# Logs y caché
storage/logs/*.log
storage/logs/*.json
storage/rates/*.json
storage/cache/*
!storage/cache/.gitkeep
!storage/logs/.gitkeep

# Archivos subidos por usuarios
public/storage/uploads/*
storage/cvs/*
!public/storage/uploads/.gitkeep
!storage/cvs/.gitkeep

# Dependencias (si se usan en el futuro)
/vendor/
node_modules/

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Temporales
*.tmp
*.bak
*.swp
*~
