# ===========================================
# DATA WYRD OS - CONFIGURACIÓN DE ENTORNO
# ===========================================

# ===========================================
# VARIABLE OBLIGATORIA: local | demo | production
# ===========================================
ENVIRONMENT=local

# ===========================================
# APLICACIÓN
# ===========================================
APP_NAME="Data Wyrd OS"
APP_URL=http://localhost/datawyrd
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_CHARSET=UTF-8

# ===========================================
# BASE DE DATOS
# ===========================================
# Configuración de Base de Datos
DB_HOST=localhost
DB_DATABASE=datawyrd
DB_USERNAME=root
DB_PASSWORD=

# Configuración de Correo (SMTP)
MAIL_ENABLED=false
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_NAME="Data Wyrd OS"
MAIL_FROM_ADDRESS=contacto@datawyrd.com


# ===========================================
# SEGURIDAD Y LÍMITES
# ===========================================
APP_KEY=generar_clave_32_caracteres
MAX_UPLOAD_SIZE=10485760
SESSION_LIFETIME=14400
SESSION_HEARTBEAT=300
SESSION_WARNING=300

# ===========================================
# SECURITY HARDENING
# ===========================================
AUTH_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY=60
AUTH_BRUTE_FORCE_BLOCK=1800
AUTH_ACCOUNT_LOCK=900
AUTH_HASH_ALGO=argon2id
JWT_SECRET=super-secret-token-change-this
JWT_TTL=3600

# ===========================================
# RBAC & INTELLIGENCE
# ===========================================
RBAC_MODE=granular
LEAD_SCORING_ENABLED=true
ROI_METRICS_ENABLED=true
INTERNAL_EVENTS_ENABLED=true

# ===========================================
# PARÁMETROS DE NEGOCIO (SLA & BRANDING)
# ===========================================
COMPANY_NAME="Data Wyrd"
COMPANY_SLOGAN="Ingeniería de Datos de Vanguardia"
COMPANY_MAIL="contacto@datawyrd.com"
COMPANY_ADDRESS="Buenos Aires, Argentina"
SLA_RESPONSE_TIME="24h"
CURRENCY_SYMBOL="$"
TAX_RATE=0.21
SHOW_ENTERPRISE_PROFILE=false
COMPANY_YEARS_EXP=10
COMPANY_PROJECTS_DELIVERED=45

# ===========================================
# PASARELAS DE PAGO (MERCADOPAGO)
# ===========================================
MP_ACCESS_TOKEN=tu-access-token-aqui
MP_PUBLIC_KEY=tu-public-key-aqui
MP_CURRENCY_ID=ARS
MP_EXCHANGE_RATE=1050.00

# ===========================================
# INSTRUCCIONES BANCARIAS (TRANSFERENCIAS)
# ===========================================
BANK_NAME="Ecosistema Digital Bank"
BANK_ACCOUNT_NAME="Data Wyrd Services LLC"
BANK_ACCOUNT_NUMBER="1234-5678-9012"
BANK_CBU_ALIAS="datawyrd.usd"

# ===========================================
# MODULO GAI (GENERATIVE AI)
# ===========================================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
