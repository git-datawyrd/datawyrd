# ===========================================
# DATA WYRD OS - CONFIGURACIÓN DE ENTORNO
# ===========================================

# ===========================================
# VARIABLE OBLIGATORIA: local | demo | production
# ===========================================
ENVIRONMENT=local

# ===========================================
# APLICACIÓN
# ===========================================
APP_NAME="Data Wyrd OS"
APP_URL=http://localhost/datawyrd
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_CHARSET=UTF-8

# ===========================================
# BASE DE DATOS
# ===========================================
# Configuración de Base de Datos
DB_HOST=localhost
DB_DATABASE=datawyrd
DB_USERNAME=root
DB_PASSWORD=

# Configuración de Correo (SMTP)
MAIL_ENABLED=false
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_NAME="Data Wyrd OS"
MAIL_FROM_ADDRESS=contacto@datawyrd.com


# ===========================================
# SEGURIDAD Y LÍMITES
# ===========================================
APP_KEY=generar_clave_32_caracteres
MAX_UPLOAD_SIZE=10485760
SESSION_LIFETIME=14400
SESSION_HEARTBEAT=300
SESSION_WARNING=300

# ===========================================
# SECURITY HARDENING
# ===========================================
AUTH_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY=60
AUTH_BRUTE_FORCE_BLOCK=1800
AUTH_ACCOUNT_LOCK=900
AUTH_HASH_ALGO=argon2id
JWT_SECRET=super-secret-token-change-this
JWT_TTL=3600

# ===========================================
# RBAC & INTELLIGENCE
# ===========================================
RBAC_MODE=granular
LEAD_SCORING_ENABLED=true
ROI_METRICS_ENABLED=true
INTERNAL_EVENTS_ENABLED=true

# ===========================================
# PARÁMETROS DE NEGOCIO (SLA & BRANDING)
# ===========================================
COMPANY_NAME="Data Wyrd"
COMPANY_SLOGAN="Ingeniería de Datos de Vanguardia"
COMPANY_MAIL="contacto@datawyrd.com"
COMPANY_ADDRESS="Buenos Aires, Argentina"
SLA_RESPONSE_TIME="24h"
CURRENCY_SYMBOL="$"
TAX_RATE=0.21
SHOW_ENTERPRISE_PROFILE=false
COMPANY_YEARS_EXP=10
COMPANY_PROJECTS_DELIVERED=45

# ===========================================
# PASARELAS DE PAGO (MERCADOPAGO)
# ===========================================
MP_ACCESS_TOKEN=tu-access-token-aqui
MP_PUBLIC_KEY=tu-public-key-aqui
MP_CURRENCY_ID=ARS
MP_EXCHANGE_RATE=1050.00

# ===========================================
# INSTRUCCIONES BANCARIAS (TRANSFERENCIAS)
# ===========================================
BANK_NAME="Ecosistema Digital Bank"
BANK_ACCOUNT_NAME="Data Wyrd Services LLC"
BANK_ACCOUNT_NUMBER="1234-5678-9012"
BANK_CBU_ALIAS="datawyrd.usd"

# ===========================================
# MODULO GAI (GENERATIVE AI)
# ===========================================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ===========================================
# MÓDULO DE EMAIL MARKETING & ENGAGEMENT
# ===========================================

# Proveedor de envío masivo: smtp | zepto | sendgrid | mailgun
MARKETING_PROVIDER=smtp

# --- ZeptoMail (recomendado para producción) ---
ZEPTO_API_KEY=
ZEPTO_API_URL=https://api.zeptomail.com/v1.1/email
ZEPTO_FROM_ADDRESS=marketing@tudominio.com
ZEPTO_FROM_NAME="Data Wyrd"
ZEPTO_BOUNCE_ADDRESS=bounces@tudominio.com

# --- Rate Limiting & Throttle ---
MARKETING_BATCH_SIZE=50
MARKETING_DELAY_MS=200
MARKETING_MAX_PER_HOUR=500
MARKETING_MAX_PER_DAY=5000

# --- Tracking ---
MARKETING_PIXEL_ENABLED=true
MARKETING_CLICK_ENABLED=true
MARKETING_TRACKING_URL=

# --- Cumplimiento GDPR / CAN-SPAM / RFC 8058 ---
MARKETING_UNSUB_ENABLED=true
MARKETING_LIST_UNSUB_HEADER=true
MARKETING_DOUBLE_OPT_IN=false
MARKETING_GDPR_CONSENT=false
MARKETING_SUPPRESS_BOUNCED=true
MARKETING_SUPPRESS_COMPLAINED=true

# --- Reintentos ---
MARKETING_MAX_RETRIES=3
MARKETING_RETRY_DELAY=300

# --- Reputación / DKIM ---
MARKETING_DKIM_DOMAIN=
MARKETING_CUSTOM_DOMAIN=

# ===========================================
# MITIGACIÓN DE BOTS & CAPTCHA
# ===========================================
# Opciones: local (matemático) | turnstile (Cloudflare) | recaptcha (Google)
CAPTCHA_PROVIDER=local
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
CAPTCHA_HONEYPOT_NAME=website_extra

